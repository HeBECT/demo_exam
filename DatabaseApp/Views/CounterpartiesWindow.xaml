<Window x:Class="DatabaseApp.Views.CounterpartiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Контрагенты" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="Добавить" Width="100" Height="30" Margin="5" 
                    Click="AddButton_Click"/>
            <Button Content="Редактировать" Width="100" Height="30" Margin="5" 
                    Click="EditButton_Click"/>
            <Button Content="Удалить" Width="100" Height="30" Margin="5" 
                    Click="DeleteButton_Click"/>
            <Button Content="Обновить" Width="100" Height="30" Margin="5" 
                    Click="RefreshButton_Click"/>
        </StackPanel>

        <!-- Таблица данных -->
        <DataGrid Grid.Row="1" x:Name="CounterpartiesDataGrid" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding CounterpartyId}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="120"/>
                <DataGridTextColumn Header="КПП" Binding="{Binding Kpp}" Width="100"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding CounterpartyType}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
