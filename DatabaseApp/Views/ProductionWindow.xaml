<Window x:Class="DatabaseApp.Views.ProductionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Производство" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Документы производства" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Таблица данных -->
        <DataGrid Grid.Row="1" x:Name="ProductionDataGrid" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  AlternatingRowBackground="LightGray"
                  GridLinesVisibility="All">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ProductionId}" Width="60"/>
                <DataGridTextColumn Header="Номер" Binding="{Binding ProductionNumber}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding ProductionDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Продукция" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Код" Binding="{Binding ProductCode}" Width="120"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Ед.изм." Binding="{Binding Unit}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Просмотр" Width="100" Height="35" Margin="0,0,10,0"
                    Click="ViewButton_Click"/>
            <Button Content="Обновить" Width="100" Height="35"
                    Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
