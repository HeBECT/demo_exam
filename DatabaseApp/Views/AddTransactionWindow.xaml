<Window x:Class="DatabaseApp.Views.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление проводки" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Дата:" Margin="0,5"/>
        <DatePicker Grid.Row="0" x:Name="DatePicker" Height="25" Margin="150,5,0,5"/>

        <TextBlock Grid.Row="1" Text="Счет дебета:" Margin="0,5"/>
        <TextBox Grid.Row="1" x:Name="DebitAccountTextBox" Height="25" Margin="150,5,0,5"/>

        <TextBlock Grid.Row="2" Text="Счет кредита:" Margin="0,5"/>
        <TextBox Grid.Row="2" x:Name="CreditAccountTextBox" Height="25" Margin="150,5,0,5"/>

        <TextBlock Grid.Row="3" Text="Сумма:" Margin="0,5"/>
        <TextBox Grid.Row="3" x:Name="AmountTextBox" Height="25" Margin="150,5,0,5"/>

        <TextBlock Grid.Row="4" Text="Описание:" Margin="0,5"/>
        <TextBox Grid.Row="5" x:Name="DescriptionTextBox" TextWrapping="Wrap" 
                 AcceptsReturn="True" Margin="0,5"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="100" Height="30" Margin="5" Click="SaveButton_Click"/>
            <Button Content="Отмена" Width="100" Height="30" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
