<Window x:Class="DatabaseApp.Views.AccountsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Счета бухгалтерского учета" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="Обновить" Width="100" Height="30" Margin="5" 
                    Click="RefreshButton_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="AccountsDataGrid" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер счета" Binding="{Binding AccountNumber}" Width="120"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding AccountName}" Width="*"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding AccountType}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
