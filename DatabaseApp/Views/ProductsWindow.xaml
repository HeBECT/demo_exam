<Window x:Class="DatabaseApp.Views.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Продукция и материалы" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Справочник продукции и материалов" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Таблица данных -->
        <DataGrid Grid.Row="1" x:Name="ProductsDataGrid" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  AlternatingRowBackground="LightGray"
                  GridLinesVisibility="All">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="60"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Ед.изм." Binding="{Binding Unit}" Width="80"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding ProductType}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Добавить" Width="100" Height="35" Margin="0,0,10,0"
                    Click="AddButton_Click"/>
            <Button Content="Редактировать" Width="120" Height="35" Margin="0,0,10,0"
                    Click="EditButton_Click"/>
            <Button Content="Удалить" Width="100" Height="35" Margin="0,0,10,0"
                    Click="DeleteButton_Click"/>
            <Button Content="Обновить" Width="100" Height="35"
                    Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
