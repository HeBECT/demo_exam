<Window x:Class="DatabaseApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="700" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="30">
            <StackPanel>
                <TextBlock Text="Система бухгалтерского учета" 
                           FontSize="24" FontWeight="Bold"
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Вход в систему" 
                           FontSize="16"
                           Foreground="White" 
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Форма входа -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="60,20,60,20">
            <!-- Поле логина -->
            <TextBlock Text="Логин:" 
                       Margin="0,20,0,10" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Foreground="#000000"
                       Background="Transparent"/>
            <TextBox x:Name="UsernameTextBox" 
                     Height="45" 
                     FontSize="16" 
                     Padding="12,10"
                     BorderThickness="2" 
                     BorderBrush="#CCCCCC"
                     VerticalContentAlignment="Center"/>
            
            <!-- Поле пароля -->
            <TextBlock Text="Пароль:" 
                       Margin="0,25,0,10" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Foreground="#000000"
                       Background="Transparent"/>
            <PasswordBox x:Name="PasswordBox" 
                         Height="45" 
                         FontSize="16" 
                         Padding="12,10"
                         BorderThickness="2" 
                         BorderBrush="#CCCCCC"
                         VerticalContentAlignment="Center"/>
            
            <!-- Кнопка входа -->
            <Button x:Name="LoginButton" 
                    Content="Войти" 
                    Height="50" 
                    FontSize="17" 
                    FontWeight="Bold"
                    Click="LoginButton_Click"
                    Margin="0,30,0,0" 
                    Background="#2196F3" 
                    Foreground="White" 
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="3"
                                            Padding="10">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="ErrorTextBlock" 
                       Foreground="Red" 
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0" 
                       TextWrapping="Wrap"
                       FontSize="14"
                       FontWeight="Medium"/>
        </StackPanel>
        
        <!-- Подсказка -->
        <Border Grid.Row="2" Background="White" Padding="25,20" 
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel>
                <TextBlock Text="Учетные данные по умолчанию:" 
                           FontSize="13" FontWeight="Bold" 
                           Foreground="#555555"
                           Margin="0,0,0,10"/>
                <TextBlock FontSize="13" Foreground="#666666" Margin="0,4,0,0">
                    <Run Text="Администратор:" FontWeight="SemiBold"/>
                    <Run Text="admin / admin123" FontWeight="Bold" Foreground="#2196F3"/>
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#666666" Margin="0,4,0,0">
                    <Run Text="Пользователь:" FontWeight="SemiBold"/>
                    <Run Text="user / user123" FontWeight="Bold" Foreground="#2196F3"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
