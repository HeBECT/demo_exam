<Window x:Class="DemEkz.CenyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Цены" Height="500" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" x:Name="dgData"
                  AutoGenerateColumns="True" IsReadOnly="True"
                  Margin="0,0,0,10"
                  SelectionChanged="dgData_SelectionChanged"/>

        <GroupBox Grid.Row="1" Header="Добавить запись" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Наименование:"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtNazvanie" Margin="3" Height="24"/>

                <Label Grid.Row="0" Grid.Column="2" Content="Цена:"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="txtCena" Margin="3" Height="24"/>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal">
                    <Button x:Name="btnAdd" Content="Добавить" Click="BtnAdd_Click"
                            Height="30" Margin="3" Width="200"/>
                    <Button Content="Новая запись" Click="BtnClear_Click"
                            Height="30" Margin="3" Width="150"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
